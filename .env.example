# VoxScribe environment configuration
# Copy this file to .env and fill in your values.
# All variables are optional unless noted.

# ── HuggingFace token ────────────────────────────────────────────────────────
# Required for pyannote speaker diarization (best accuracy).
# Get yours at: https://huggingface.co/settings/tokens
# Then accept the model terms at: https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=

# ── Ollama (optional summarization) ─────────────────────────────────────────
# Only needed if you run `voxscribe ... --summarize`
# Default host is http://localhost:11434 (standard Ollama install)
# VOXSCRIBE_OLLAMA_HOST=http://localhost:11434
# VOXSCRIBE_OLLAMA_MODEL=llama3.2

# ── Transcription defaults ───────────────────────────────────────────────────
# Override CLI defaults via environment for persistent configuration.
# VOXSCRIBE_MODEL=base
# VOXSCRIBE_BACKEND=faster-whisper
# VOXSCRIBE_DEVICE=auto
# VOXSCRIBE_COMPUTE_TYPE=int8

# ── Output defaults ──────────────────────────────────────────────────────────
# VOXSCRIBE_OUTPUT_DIR=output
# VOXSCRIBE_FORMATS=md,json
